# Public (browser + server)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server only — create admin user in Supabase Auth dashboard
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI for Vercel AI SDK (optional — demo mode uses keyword tags without this)
OPENAI_API_KEY=sk-...

# Optional canonical URL for metadata
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Demo mode safety: max AI analyze calls per IP per hour (default 20)
AI_RATE_LIMIT_PER_HOUR=20
