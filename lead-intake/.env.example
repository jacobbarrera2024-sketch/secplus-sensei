# Public (browser + server)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# OpenAI for Vercel AI SDK (optional — demo mode uses keyword tags without this)
OPENAI_API_KEY=sk-...

# Optional canonical URL for metadata (set before production build for correct OG URLs)
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Rate limits per IP per hour (best-effort on serverless — use Upstash for strict prod limits)
AI_RATE_LIMIT_PER_HOUR=20
PUBLIC_RATE_LIMIT_PER_HOUR=20
