{
  "name": "secplus-sensei",
  "productName": "SecPlus Sensei",
  "version": "1.1.6",
  "description": "CompTIA Security+ SY0-701 study app",
  "main": "main.js",
  "author": "Jacob",
  "scripts": {
    "start": "electron .",
    "build:icon": "node build-icon.js",
    "build": "electron-builder --win nsis",
    "build:portable": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.secplus.sensei",
    "productName": "SecPlus Sensei",
    "directories": {
      "output": "dist"
    },
    "afterPack": "./embed-exe-icon.js",
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "secplus-sensei.html",
      "ninja-duck-data.js",
      "ninja-duck.glb",
      "CURRENT_VERSION.txt",
      "assets/**/*"
    ],
    "extraFiles": [
      {
        "from": "assets/icon.ico",
        "to": "appIcon.ico"
      },
      {
        "from": "build/SecPlus Sensei Updater.exe",
        "to": "."
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": false,
      "include": "build/installer.nsh",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": false,
      "createStartMenuShortcut": false,
      "shortcutName": "SecPlus Sensei",
      "uninstallDisplayName": "SecPlus Sensei",
      "menuCategory": "SecPlus Sensei"
    },
    "publish": {
      "provider": "generic",
      "url": "https://secplus-sensei.local/updates/"
    }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^2.1.8",
    "rcedit": "^5.0.2",
    "sharp": "^0.35.3"
  }
}
